{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/api/index.js"
    },
    {
      "src": "/webhook",
      "dest": "/api/index.js"
    },
    {
      "src": "/create-checkout-session",
      "dest": "/api/index.js"
    },
    {
      "src": "/success",
      "dest": "/api/index.js"
    },
    {
      "src": "/cancel",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
